# Cloud Panel configuration (copy to .env or set in your environment)

# ---- Network (PufferPanel ports) ----
CP_WEB_PORT=8080         # PufferPanel web port
CP_SFTP_PORT=5657        # PufferPanel SFTP port
CP_HOST=0.0.0.0
CP_PUBLIC_HOST=127.0.0.1

# ---- Security ----
CP_JWT_SECRET=change-me-to-a-long-random-string
CP_JWT_TTL=7d
CP_BCRYPT_ROUNDS=10

# ---- Game-server allocation port range ----
CP_ALLOC_START=25565
CP_ALLOC_END=25600

# ---- Storage ----
# Real database lives at data/cloud-panel.db (SQLite). Set to 1 to force the
# JSON fallback store instead of SQLite.
CP_FORCE_JSON=0
