# Cloud Panel configuration (copy to .env or set in your environment)

# ---- Network (PufferPanel ports) ----
CP_WEB_PORT=8080         # PufferPanel web port
CP_SFTP_PORT=5657        # PufferPanel SFTP port
CP_HOST=0.0.0.0          # bind address (0.0.0.0 = reachable on every interface)

# The domain or IP you use to reach the panel in a browser. Visiting it on
# CP_WEB_PORT loads Cloud Panel. Examples:
#   CP_PUBLIC_HOST=panel.yourdomain.com
#   CP_PUBLIC_HOST=203.0.113.10
CP_PUBLIC_HOST=127.0.0.1

# Trust X-Forwarded-* headers. Keep this 0 unless the panel is behind a reverse
# proxy / Cloudflare Tunnel — trusting these on a directly-reachable panel lets
# clients spoof their IP and bypass rate limiting. Behind a proxy, set it to the
# number of hops (e.g. 1).
CP_TRUST_PROXY=0

# ---- Security ----
CP_JWT_SECRET=change-me-to-a-long-random-string
CP_JWT_TTL=7d
CP_BCRYPT_ROUNDS=10

# ---- OCI container sandbox (recommended for untrusted users) ----
# Run every game/app server inside its own OCI container (Docker or Podman)
# instead of as a host process. The container is the sandbox: server code can't
# read the panel's data/secrets, other servers' files, or the host — even for
# code-running eggs (Node/Python/jar). Eggs already declare their image.
#
# Opt-in + loud-on-misconfig: with CP_OCI=1, if the engine is missing, servers
# REFUSE TO START (they never silently run unsandboxed). Needs Docker or Podman
# installed and reachable by the panel user (e.g. add it to the 'docker' group).
CP_OCI=0                       # 1 = require containers for every server
CP_OCI_RUNTIME=docker          # container engine CLI: docker | podman
# CP_OCI_IMAGE=eclipse-temurin:21-jre   # fallback image only for eggs without one
# CP_OCI_BIND=                  # host IP to publish game ports on ("" = all)
# CP_OCI_NETWORK=               # "" = bridge + published ports; or "host", a net name
# CP_OCI_USER=                  # run as in-container uid[:gid] ("" = image default)
# CP_OCI_PIDS_LIMIT=512         # max procs/threads per container (anti fork-bomb; 0 = off)
# CP_OCI_CPU_LIMIT=1            # cap --cpus from each server's CPU limit (100 = 1 core)
# CP_OCI_READONLY=0             # 1 = read-only rootfs (+ tmpfs /tmp); strictest
# CP_OCI_PULL=missing           # image pull policy on start: missing | always | never
# CP_OCI_EXTRA_ARGS=            # advanced: extra args appended to every `run`

# ---- Secure by default (audit C1) ----
# With NO sandbox active (neither CP_OCI nor CP_SERVER_UID/GID), a running server
# executes code as the panel user and could read the panel's JWT secret / DB. So
# servers REFUSE TO START unless a sandbox is active OR you explicitly accept the
# risk here. Set 1 ONLY for a trusted, single-operator panel; for any untrusted /
# multi-user panel, enable CP_OCI=1 instead. (Also toggleable at
# Admin -> Settings: security.allowUnsandboxed.)
CP_ALLOW_UNSANDBOXED=0          # 1 = allow running servers with no sandbox (trusted panels only)

# ---- Game-server allocation port range ----
CP_ALLOC_START=25565
CP_ALLOC_END=25600

# ---- Storage ----
# Real database lives at data/cloud-panel.db (SQLite). Set to 1 to force the
# JSON fallback store instead of SQLite.
CP_FORCE_JSON=0
